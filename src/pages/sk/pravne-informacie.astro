---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import LegalPage from '../../components/LegalPage.astro';
import { siteCopy } from '../../content/site';

const copy = siteCopy.sk;
const buildDate = new Date();
const buildDateLabel = new Intl.DateTimeFormat('sk-SK', { day: 'numeric', month: 'long', year: 'numeric' }).format(buildDate);
---

<SiteLayout
  title="Právne informácie a ochrana súkromia | Pudilar"
  description="Právne informácie, podrobnosti o ochrane súkromia a investičné upozornenie spoločnosti Pudilar s. r. o."
  locale="sk"
  canonicalPath="/sk/pravne-informacie/"
  alternatePath="/legal/"
  isLegal
>
  <Header locale="sk" copy={copy} isLegal />
  <LegalPage copy={copy} buildDateLabel={buildDateLabel} />
  <Footer locale="sk" copy={copy} year={buildDate.getFullYear()} isLegal />
</SiteLayout>
