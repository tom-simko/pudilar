---
interface Props {
  caption: string;
}

const { caption } = Astro.props;
---

<figure class="hero-visual reveal" aria-labelledby="universe-title universe-description">
  <svg viewBox="0 0 720 620" role="img" focusable="false">
    <title id="universe-title">Illustrative investment universe</title>
    <desc id="universe-description">An abstract orbital system representing different investment areas around a central point.</desc>
    <defs>
      <linearGradient id="orbit-gradient" x1="0" x2="1" y1="0" y2="1">
        <stop offset="0" stop-color="#9eaa8a" stop-opacity="0.1" />
        <stop offset="0.5" stop-color="#9eaa8a" stop-opacity="0.72" />
        <stop offset="1" stop-color="#a9895c" stop-opacity="0.14" />
      </linearGradient>
      <radialGradient id="core-glow">
        <stop offset="0" stop-color="#f4f1e9" stop-opacity="0.85" />
        <stop offset="1" stop-color="#9eaa8a" stop-opacity="0" />
      </radialGradient>
    </defs>
    <g class="universe-grid" fill="none" stroke="currentColor" stroke-opacity="0.12">
      <circle cx="360" cy="290" r="246" />
      <circle cx="360" cy="290" r="184" />
      <circle cx="360" cy="290" r="112" />
      <path d="M93 290h534M360 24v532" />
    </g>
    <g class="universe-orbits" fill="none" stroke="url(#orbit-gradient)">
      <ellipse class="orbit-trace orbit-trace--one" cx="360" cy="290" rx="252" ry="138" transform="rotate(-19 360 290)" stroke-width="1.4" />
      <ellipse class="orbit-trace orbit-trace--two" cx="360" cy="290" rx="210" ry="218" transform="rotate(35 360 290)" stroke-width="1" />
      <ellipse class="orbit-trace orbit-trace--three" cx="360" cy="290" rx="138" ry="256" transform="rotate(73 360 290)" stroke-width="1.2" />
    </g>
    <g class="universe-connectors" fill="none" stroke="currentColor" stroke-opacity="0.44" stroke-width="1">
      <path d="M360 290L183 159M360 290L555 164M360 290L565 420M360 290L171 439" />
    </g>
    <circle class="universe-core-glow" cx="360" cy="290" r="70" fill="url(#core-glow)" />
    <circle class="universe-core" cx="360" cy="290" r="4.5" fill="#f4f1e9" />
    <circle class="universe-node universe-node--real" cx="183" cy="159" r="7" fill="#9eaa8a" />
    <circle class="universe-node universe-node--private" cx="555" cy="164" r="7" fill="#a9895c" />
    <circle class="universe-node universe-node--public" cx="565" cy="420" r="7" fill="#9eaa8a" />
    <circle class="universe-node universe-node--digital" cx="171" cy="439" r="7" fill="#a9895c" />
    <g class="universe-labels" fill="currentColor" font-family="Arial, sans-serif">
      <text x="159" y="132" text-anchor="end">REAL ASSETS</text>
      <text x="578" y="139">PRIVATE COMPANIES</text>
      <text x="588" y="438">PUBLIC MARKETS</text>
      <text x="154" y="468" text-anchor="end">DIGITAL ASSETS</text>
      <text x="360" y="322" text-anchor="middle" class="universe-center-label">DISCIPLINED ALLOCATION</text>
    </g>
  </svg>
  <figcaption>{caption}</figcaption>
</figure>
