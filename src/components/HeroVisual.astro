---
interface Props {
  caption: string;
}

const { caption } = Astro.props;
---

<figure class="hero-visual reveal" aria-labelledby="patient-title patient-description">
  <svg viewBox="0 0 720 540" role="img" focusable="false">
    <title id="patient-title">{caption}</title>
    <desc id="patient-description">A stable origin surrounded by successive time rings and gradually widening paths, representing discipline, compounding and a long investment horizon.</desc>
    <defs>
      <linearGradient id="patient-growth" x1="0" x2="1" y1="1" y2="0">
        <stop offset="0" stop-color="#9eaa8a" stop-opacity="0.02" />
        <stop offset="0.58" stop-color="#9eaa8a" stop-opacity="0.14" />
        <stop offset="1" stop-color="#a9895c" stop-opacity="0.04" />
      </linearGradient>
      <linearGradient id="patient-line" x1="0" x2="1" y1="1" y2="0">
        <stop offset="0" stop-color="#9eaa8a" stop-opacity="0.12" />
        <stop offset="0.54" stop-color="#f4f1e9" stop-opacity="0.48" />
        <stop offset="1" stop-color="#a9895c" stop-opacity="0.16" />
      </linearGradient>
      <radialGradient id="patient-origin">
        <stop offset="0" stop-color="#f4f1e9" stop-opacity="0.2" />
        <stop offset="0.32" stop-color="#9eaa8a" stop-opacity="0.09" />
        <stop offset="1" stop-color="#9eaa8a" stop-opacity="0" />
      </radialGradient>
      <clipPath id="patient-clip">
        <rect x="24" y="24" width="672" height="452" />
      </clipPath>
    </defs>

    <rect class="patient-frame" x="24" y="24" width="672" height="452" />
    <g clip-path="url(#patient-clip)">
      <rect class="patient-field" x="24" y="24" width="672" height="452" />

      <path
        class="patient-growth-field"
        d="M150 390C246 389 302 353 357 294C421 225 490 150 640 112C518 174 440 238 374 309C309 378 248 405 150 390Z"
        fill="url(#patient-growth)"
      />

      <g class="patient-rings" fill="none" stroke="url(#patient-line)">
        <circle cx="150" cy="390" r="56" />
        <circle cx="150" cy="390" r="96" />
        <circle cx="150" cy="390" r="144" />
        <circle cx="150" cy="390" r="202" />
        <circle cx="150" cy="390" r="270" />
        <circle cx="150" cy="390" r="348" />
        <circle cx="150" cy="390" r="436" />
      </g>

      <g class="patient-rays" fill="none">
        <path d="M150 390H724" />
        <path d="M150 390L724 278" />
        <path d="M150 390L694 148" />
        <path d="M150 390L574 -28" />
      </g>

      <g class="patient-paths" fill="none">
        <path class="patient-path patient-path--lower" d="M150 390C260 390 326 362 392 316C466 264 540 206 676 174" />
        <path class="patient-path patient-path--main" d="M150 390C246 389 302 353 357 294C421 225 490 150 640 112" />
        <path class="patient-path patient-path--upper" d="M150 390C231 377 274 323 318 252C373 164 446 90 570 54" />
      </g>

      <g class="patient-horizon">
        <path d="M72 390H662" />
        <circle cx="236" cy="390" r="1.5" />
        <circle cx="326" cy="390" r="1.8" />
        <circle cx="420" cy="390" r="2.1" />
        <circle cx="518" cy="390" r="2.4" />
        <circle cx="620" cy="390" r="2.7" />
      </g>

      <circle class="patient-origin-glow" cx="150" cy="390" r="94" fill="url(#patient-origin)" />
      <circle class="patient-origin-ring patient-origin-ring--outer" cx="150" cy="390" r="29" />
      <circle class="patient-origin-ring" cx="150" cy="390" r="12" />
      <circle class="patient-origin-dot" cx="150" cy="390" r="3.5" />

      <circle class="patient-terminal-ring" cx="640" cy="112" r="10" />
      <circle class="patient-terminal-dot" cx="640" cy="112" r="3" />

      <path class="patient-shade" d="M24 438C190 419 302 360 386 283C476 201 560 142 696 99V476H24Z" />
    </g>

    <g class="patient-corners" fill="none">
      <path d="M24 58V24H58M662 24H696V58M24 442V476H58M662 476H696V442" />
    </g>
  </svg>
  <figcaption>{caption}</figcaption>
</figure>
